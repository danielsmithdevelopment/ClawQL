{
    "name": "clawql-mcp-server",
    "version": "1.0.0",
    "description": "MCP server: search + execute any OpenAPI 3 API with an internal GraphQL optimization layer",
    "license": "Apache-2.0",
    "type": "module",
    "main": "dist/server.js",
    "bin": {
        "clawql-mcp": "./bin/clawql-mcp.mjs",
        "clawql-graphql": "./bin/clawql-graphql.mjs"
    },
    "engines": {
        "node": ">=18"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/danielsmithdevelopment/ClawQL.git"
    },
    "keywords": [
        "mcp",
        "model-context-protocol",
        "gcp",
        "google",
        "graphql",
        "openapi",
        "openapi-3",
        "cloudflare",
        "rest",
        "claude",
        "cursor"
    ],
    "files": [
        "dist",
        "bin",
        "src",
        "providers",
        "scripts",
        "README.md",
        "docs/benchmarks",
        "docs/benchmarks/response-examples",
        "docs/workflow-multi-provider.md",
        "docs/workflow-complex-release-stack.md",
        "docs/google-apis-lookup.md",
        "docs/workflow-gcp-multi-service.md",
        "docs/gcp-multi-mcp-test-summary.md",
        "docs/experiment-gcp-multi-mcp-workflow.md",
        "docs/experiment-gcp-multi-mcp-stats.json",
        "LICENSE",
        ".env.example"
    ],
    "scripts": {
        "build": "tsc",
        "prepare": "npm run build",
        "prepublishOnly": "npm run build",
        "start": "node dist/server.js",
        "dev": "tsx src/server.ts",
        "graphql": "node dist/graphql-proxy.js",
        "fetch-provider-specs": "node scripts/fetch-provider-specs.mjs && node scripts/fetch-google-discovery-directory.mjs",
        "fetch-n8n-openapi": "node scripts/fetch-n8n-openapi.mjs",
        "fetch-google-discovery-directory": "node scripts/fetch-google-discovery-directory.mjs",
        "fetch-all-google-discovery-specs": "node scripts/fetch-all-google-discovery-specs.mjs",
        "fetch-google-top50": "node scripts/fetch-google-top50.mjs",
        "pregenerate-google-top50-graphql": "bun scripts/pregenerate-google-top50-graphql.ts",
        "refresh-google-top50": "npm run fetch-google-top50 && npm run build && npm run pregenerate-google-top50-graphql",
        "pregenerate-graphql": "bun scripts/pregenerate-provider-graphql.ts",
        "smoke:atlassian": "node scripts/smoke-atlassian.mjs",
        "smoke:cloudflare": "node scripts/smoke-cloudflare.mjs",
        "benchmark:tokens": "npm run build && node scripts/benchmark-provider-tokens.mjs",
        "workflow:multi-provider": "npm run build && node scripts/workflow-gke-cloudflare-jira.mjs",
        "workflow:complex-release-stack": "npm run build && node scripts/workflow-complex-release-stack.mjs",
        "workflow:gcp-multi": "npm run build && node scripts/mcp-workflow-gcp-multi.mjs",
        "workflow:gcp-multi:direct": "npm run build && node scripts/workflow-gcp-multi-direct.mjs",
        "report:gcp-multi-experiment": "node scripts/report-gcp-multi-experiment.mjs",
        "report:all-providers-benchmark": "npm run build && node scripts/report-all-providers-workflow-benchmark.mjs",
        "test": "bun test src"
    },
    "dependencies": {
        "@graphql-mesh/utils": "^0.104.29",
        "@modelcontextprotocol/sdk": "^1.0.0",
        "@omnigraph/openapi": "^0.109.41",
        "clawql-mcp-server": "github:danielsmithdevelopment/ClawQL",
        "express": "^4.18.2",
        "graphql": "^16.8.1",
        "graphql-http": "^1.22.0",
        "node-fetch": "^3.3.2",
        "swagger2openapi": "^7.0.8",
        "yaml": "^2.8.2",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^20.0.0",
        "tsx": "^4.7.0",
        "typescript": "^5.3.0"
    }
}
