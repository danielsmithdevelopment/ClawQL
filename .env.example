# ─── API spec (pick one) ─────────────────────────────────────────────
# Built-in bundled spec (jira | google | cloudflare). Lowest priority after explicit spec URLs/paths.
# CLAWQL_PROVIDER=jira

# If set, bundled providers never fetch the remote fallback when the local file is missing.
# CLAWQL_BUNDLED_OFFLINE=1

# ─── Multi-spec (one process, many Google / OpenAPI files) ───────────
# If either line below is set, it takes precedence over CLAWQL_SPEC_PATH / CLAWQL_DISCOVERY_URL.
# Merge curated GCP APIs from repo (see providers/google/google-top20-apis.json).
# CLAWQL_GOOGLE_TOP20_SPECS=1
# Or list paths (comma, semicolon, or newline). Labels = parent folder name.
# CLAWQL_SPEC_PATHS=providers/google/apis/compute-v1/discovery.json,providers/google/apis/container-v1/discovery.json

# Local OpenAPI 3 file (JSON or YAML). Overrides the default bundled provider (cloudflare).
# CLAWQL_SPEC_PATH=./openapi.yaml

# Fetch OpenAPI from URL (JSON or YAML).
# CLAWQL_SPEC_URL=https://petstore3.swagger.io/api/v3/openapi.json

# Google Discovery document URL (non-OpenAPI).
# CLAWQL_DISCOVERY_URL=https://run.googleapis.com/$discovery/rest?version=v2

# Base URL for REST calls (overrides servers[0].url in the spec if set).
# CLAWQL_API_BASE_URL=https://api.example.com

# ─── GraphQL proxy (MCP execute tool) ────────────────────────────────
# GRAPHQL_URL=http://localhost:4000/graphql
# GRAPHQL_PORT=4000

# Optional: pregenerated introspection JSON (skips live introspection for execute field names).
# CLAWQL_INTROSPECTION_PATH=./introspection.json
