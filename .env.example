# ─── API spec selection ───────────────────────────────────────────────
# Two stages (same story as README "Configure the API spec"):
#
# Stage 1 — Multi-spec merge (merged operation index), if any applies:
#   1) CLAWQL_SPEC_PATHS
#   2) CLAWQL_PROVIDER = merged preset (google-top50, default-multi-provider, all-providers, atlassian, …)
#   3) CLAWQL_GOOGLE_TOP50_SPECS=1  (if #2 did not already pick multi-spec)
#   4) Else if SPEC_PATHS / PATH / URL / DISCOVERY / CLAWQL_PROVIDER / GOOGLE_TOP50 are all unset →
#      built-in default merge (google top50 + cloudflare + jira)
#
# Stage 2 — Single spec (if Stage 1 does not apply), first match wins:
#   CLAWQL_SPEC_PATH > CLAWQL_SPEC_URL > CLAWQL_DISCOVERY_URL > CLAWQL_PROVIDER (single vendor)

# Multi-spec mode (one process, merged operation index)
# - Curated Google top50 from providers/google/google-top50-apis.json:
# CLAWQL_GOOGLE_TOP50_SPECS=1
# - OR explicit list of local spec files (comma, semicolon, or newline separated):
# CLAWQL_SPEC_PATHS=providers/google/apis/compute-v1/discovery.json,providers/google/apis/container-v1/discovery.json

# Single explicit spec (OpenAPI / Discovery)
# CLAWQL_SPEC_PATH=./openapi.yaml
# CLAWQL_SPEC_URL=https://petstore3.swagger.io/api/v3/openapi.json
# (Relative servers[].url is resolved against this document URL; CLAWQL_API_BASE_URL overrides.)
# CLAWQL_DISCOVERY_URL=https://run.googleapis.com/$discovery/rest?version=v2

# Bundled preset (used when explicit spec vars above are not set)
# Single specs: google | atlassian | cloudflare | github | slack | sentry | n8n
# Merged presets: google-top50 | default-multi-provider | all-providers | atlassian
# all-providers = Google top50 + every other bundled vendor (jira, bitbucket, cloudflare, …)
# CLAWQL_PROVIDER=google

# Optional: fail fast if bundled local file is missing (never fetch fallback URL)
# CLAWQL_BUNDLED_OFFLINE=1

# Base URL for REST calls (overrides servers[0].url in the spec if set).
# CLAWQL_API_BASE_URL=https://api.example.com

# ─── GraphQL proxy (MCP execute tool) ────────────────────────────────
# GRAPHQL_URL=http://localhost:4000/graphql
# GRAPHQL_PORT=4000

# ─── MCP transport (remote/server deployment) ─────────────────────────
# Stdio entrypoint:   npm start
# HTTP entrypoint:    npm run start:http
# PORT=8080
# MCP_PORT=8080
# MCP_PATH=/mcp

# Browser / Gallery skill: set to * (or a specific origin) so CORS allows fetch + mcp-session-id.
# CLAWQL_CORS_ALLOW_ORIGIN=*

# Optional: pregenerated introspection JSON (skips live introspection for execute field names).
# CLAWQL_INTROSPECTION_PATH=./introspection.json

# ─── Workflow test toggles ─────────────────────────────────────────────
# Multi-provider workflow: default to dry-run (show request details, do not POST).
WORKFLOW_PREVIEW_JIRA_REQUEST=1
# Set to 1 to actually POST Jira issue.
# WORKFLOW_CREATE_JIRA_ISSUE=1
