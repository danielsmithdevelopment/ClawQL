# ─── API spec selection ───────────────────────────────────────────────
# Two stages (same story as README "Configure the API spec"):
#
# Stage 1 — Multi-spec merge (merged operation index), if any applies:
#   1) CLAWQL_SPEC_PATHS
#   2) CLAWQL_BUNDLED_PROVIDERS = comma-separated ids from BUNDLED_PROVIDERS + optional "google" (GCP manifest)
#   3) CLAWQL_PROVIDER = merged preset (google, all-providers, atlassian, …)
#   4) Else if nothing selected multi and PATH / URL / DISCOVERY unset → all-providers (default)
#
# Stage 2 — Single spec (if Stage 1 does not apply), first match wins:
#   CLAWQL_SPEC_PATH > CLAWQL_SPEC_URL > CLAWQL_DISCOVERY_URL > CLAWQL_PROVIDER (single vendor)

# Multi-spec mode (one process, merged operation index)
# - List local spec files (comma, semicolon, or newline separated):
# CLAWQL_SPEC_PATHS=providers/google/apis/compute-v1/discovery.json,providers/google/apis/container-v1/discovery.json
# - Or merge bundled vendors by id (plus optional "google" = full GCP on-disk set):
# CLAWQL_BUNDLED_PROVIDERS=github,cloudflare,slack,n8n

# Single explicit spec (OpenAPI / Discovery)
# CLAWQL_SPEC_PATH=./openapi.yaml
# CLAWQL_SPEC_URL=https://petstore3.swagger.io/api/v3/openapi.json
# (Relative servers[].url is resolved against this document URL; CLAWQL_API_BASE_URL overrides.)
# CLAWQL_DISCOVERY_URL=https://run.googleapis.com/$discovery/rest?version=v2

# Bundled preset (used when explicit spec vars above are not set)
# Single specs: atlassian | cloudflare | github | slack | sentry | n8n | tika | gotenberg | paperless | stirling | onyx
# Merged presets: google | all-providers | atlassian
# all-providers = Google Cloud (bundled) + every other bundled vendor (jira, bitbucket, cloudflare, …)
# CLAWQL_PROVIDER=google

# Optional: fail fast if bundled local file is missing (never fetch fallback URL)
# CLAWQL_BUNDLED_OFFLINE=1

# Base URL for REST calls (overrides servers[0].url in the spec if set).
# CLAWQL_API_BASE_URL=https://api.example.com

# ─── Upstream API auth (execute / GraphQL proxy) ─────────────────────
# clawql-mcp loads `.env` from this repo and from `process.cwd()` (cwd overrides).
# Local Docker Desktop k8s: `bash scripts/k8s-docker-desktop-set-mcp-auth.sh` syncs these into Secret `clawql-github-auth` on `deployment/clawql-mcp-http` (optional `.env`; see docker/README.md).
# Multi-spec default: set tokens for each vendor you call (see src/auth-headers.ts and README).
# Option A — one JSON object, keys = merged specLabel (github, cloudflare, slack, compute-v1, …).
# Use "google" as catch-all for all Google Cloud Discovery slugs unless you set a slug-specific key.
# Values: bare string → Authorization: Bearer …, or {"Authorization":"Token …","X-Custom":"1"}.
# CLAWQL_PROVIDER_AUTH_JSON={"github":"ghp_…","cloudflare":"…","google":"ya29.…","slack":"xoxb-…","paperless":"…"}
# Option B — per-vendor env vars (merged with Option A; map entries win on conflict):
# CLAWQL_GOOGLE_ACCESS_TOKEN=…   # or GOOGLE_ACCESS_TOKEN (e.g. gcloud auth print-access-token)
# CLAWQL_CLOUDFLARE_API_TOKEN=…
# CLAWQL_GITHUB_TOKEN=ghp_…
# Optional fallback for other merged vendors or single-vendor mode:
# CLAWQL_BEARER_TOKEN=…
# Global extra headers (X-*, etc.). If CLAWQL_PROVIDER_AUTH_JSON is unset, Authorization here applies to every call.
# CLAWQL_HTTP_HEADERS={"X-Trace-Id":"…"}

# Self-hosted document stack (merged `specLabel` base URLs; see providers/README.md, GitHub #111)
# PAPERLESS_BASE_URL=http://paperless:8000
# PAPERLESS_API_TOKEN=…
# STIRLING_BASE_URL=http://stirling-pdf:8080
# STIRLING_API_KEY=…
# TIKA_BASE_URL=http://tika:9998
# GOTENBERG_BASE_URL=http://gotenberg:3000
# Onyx API root (often ends with /api). Auth: ONYX_API_TOKEN (Bearer) for merged specLabel `onyx`.
# ONYX_BASE_URL=http://onyx:8080/api
# ONYX_API_TOKEN=…
# Optional: refresh large specs from running instances → npm run fetch-provider-specs
# (Onyx: same ONYX_BASE_URL + optional ONYX_API_TOKEN for Bearer when pulling /openapi.json)

# ─── GraphQL (single-spec execute) ───────────────────────────────────
# OpenAPI→GraphQL runs in-process in clawql-mcp / clawql-mcp-http. Streamable HTTP also serves /graphql.
# Optional: pregenerated introspection JSON speeds field matching (see CLAWQL_INTROSPECTION_PATH in README).

# ─── MCP transport (remote/server deployment) ─────────────────────────
# Stdio entrypoint:   npm start
# HTTP entrypoint:    npm run start:http
# PORT=8080
# MCP_PORT=8080
# MCP_PATH=/mcp

# Optional: Streamable HTTP GET /healthz includes merkleSnapshot + cuckooMembershipArtifactsEnabled when vault + memory.db flags match (not for default fast probes).
# CLAWQL_HEALTHZ_MEMORY_ARTIFACTS=1

# Browser / Gallery skill: set to * (or a specific origin) so CORS allows fetch + mcp-session-id.
# CLAWQL_CORS_ALLOW_ORIGIN=*

# Optional: gRPC alongside Streamable HTTP (same process as clawql-mcp-http). See README.
# Services: grpc.health.v1.Health, model_context_protocol.Mcp (protobuf; health Check service name: model_context_protocol.Mcp), mcp.transport.v1.Mcp.Session (JSON-RPC; health: mcp.transport.v1.Mcp).
# ENABLE_GRPC=1
# GRPC_PORT=50051
# GRPC_BIND=0.0.0.0
# TLS (optional): mTLS when GRPC_TLS_REQUIRE_CLIENT_CERT=1 and GRPC_TLS_CA_PATH is set.
# GRPC_TLS_CERT_PATH=/path/to/server.crt
# GRPC_TLS_KEY_PATH=/path/to/server.key
# GRPC_TLS_CA_PATH=/path/to/ca.crt
# grpc.health.v1.Health/Check is the standard probe; use grpcurl for smoke tests.
# Optional server reflection (grpcurl list/describe) — off by default for production.
# ENABLE_GRPC_REFLECTION=1

# Optional: pregenerated introspection JSON (skips live introspection for execute field names).
# CLAWQL_INTROSPECTION_PATH=./introspection.json

# ─── Feature tiers (diagram vs env) ───────────────────────────────────
# Canonical explanation: docs/readme/configuration.md § "Feature tiers"
# Always on: search, execute, audit, cache (no CLAWQL_ENABLE_* for Core).
# Default on, opt out: CLAWQL_ENABLE_MEMORY / DOCUMENTS (=0 to hide; documents also trims default all-providers merge).
# Default off, opt in: CLAWQL_ENABLE_SCHEDULE, NOTIFY, ONYX, OUROBOROS.
# sandbox_exec: always listed; needs CLAWQL_SANDBOX_BRIDGE_URL + token to run code (no separate enable flag).

# ─── Obsidian vault (memory tools) ───────────────────────────────────
# memory_ingest / memory_recall default ON. Set CLAWQL_ENABLE_MEMORY=0 to hide the tools.
# When CLAWQL_OBSIDIAN_VAULT_PATH is set, the server checks the path is readable/writable at startup.
# Docker images default to /vault (see docker/Dockerfile). Omit locally to skip the check.
# CLAWQL_OBSIDIAN_VAULT_PATH=/vault
# CLAWQL_ENABLE_MEMORY=0

# memory_ingest: load `toolOutputs` from a server path (huge files without large MCP tool JSON)
# Unset = allow. Set to 0 / false / off to disable `toolOutputsFile` reads.
# CLAWQL_MEMORY_INGEST_FILE=0
# Comma-separated absolute directory prefixes the file must live under (default: process cwd, realpath).
# CLAWQL_MEMORY_INGEST_FILE_ROOTS=/path/to/ClawQL
# CLAWQL_MEMORY_INGEST_FILE_MAX_BYTES=10000000

# Document stack: bundled tika, gotenberg, paperless, stirling, onyx in all-providers; ingest + Onyx tool. Set 0 to opt out.
# CLAWQL_ENABLE_DOCUMENTS=0

# ingest_external_knowledge — Markdown bulk + optional URL fetch (issue #40)
# CLAWQL_EXTERNAL_INGEST=1
# CLAWQL_EXTERNAL_INGEST_FETCH=1   # allow HTTPS fetch (url mode); http only for localhost

# Ephemeral in-process KV cache (issue #75) — ClawQL Core; always registered. LRU; not persisted; use memory_ingest / memory_recall for vault
# CLAWQL_CACHE_MAX_VALUE_BYTES=1048576
# CLAWQL_CACHE_MAX_ENTRIES=10000

# Enterprise audit ring buffer (issue #89) — always registered; in-process only; not durable — use memory_ingest for compliance-grade trails
# CLAWQL_AUDIT_MAX_ENTRIES=500

# Slack notify tool (issue #77) — chat.postMessage; requires Slack in loaded spec + CLAWQL_SLACK_TOKEN (or SLACK_BOT_TOKEN, …). Guide: docs/notify-tool.md
# CLAWQL_ENABLE_NOTIFY=1
# Test-only (Vitest): avoid real Slack when CLAWQL_TEST_SLACK_FETCH_STUB=1; optional CLAWQL_TEST_SLACK_FETCH_BODY (JSON text), CLAWQL_TEST_SLACK_FETCH_HTTP_OK=0 for HTTP failure path
# CLAWQL_TEST_SLACK_FETCH_STUB=1
# CLAWQL_TEST_SLACK_FETCH_BODY={"ok":true,"channel":"C01234567","ts":"1700000000.000100","message":{"text":"stub"}}
# CLAWQL_TEST_SLACK_FETCH_HTTP_OK=0

# Onyx knowledge_search_onyx tool (issue #118) — requires bundled `onyx` in the loaded merge + ONYX_BASE_URL + ONYX_API_TOKEN
# CLAWQL_ENABLE_ONYX=1
# Vitest stdio: avoid real Onyx HTTP when CLAWQL_TEST_ONYX_FETCH_STUB=1; optional CLAWQL_TEST_ONYX_FETCH_BODY (JSON text), CLAWQL_TEST_ONYX_FETCH_HTTP_OK=0
# CLAWQL_TEST_ONYX_FETCH_STUB=1

# clawql-ouroboros MCP tools (issues #141 / #142): create seed, run loop, lineage status. Without Postgres URL the event store is in-memory only.
# CLAWQL_ENABLE_OUROBOROS=1
# CLAWQL_OUROBOROS_DATABASE_URL=postgres://user:pass@host:5432/dbname
# Alternative to URL (useful with k8s Secret refs):
# CLAWQL_OUROBOROS_DB_HOST=clawql-mcp-http-ouroboros-postgres
# CLAWQL_OUROBOROS_DB_PORT=5432
# CLAWQL_OUROBOROS_DB_USER=clawql
# CLAWQL_OUROBOROS_DB_PASSWORD=...
# CLAWQL_OUROBOROS_DB_NAME=clawql_ouroboros

# memory_recall (keyword + wikilink graph; optional overrides)
# CLAWQL_MEMORY_RECALL_SCAN_ROOT=Memory
# CLAWQL_MEMORY_RECALL_LIMIT=10
# CLAWQL_MEMORY_RECALL_MAX_DEPTH=2
# CLAWQL_MEMORY_RECALL_MIN_SCORE=1
# CLAWQL_MEMORY_RECALL_MAX_FILES=2000
# CLAWQL_MEMORY_RECALL_SNIPPET_CHARS=520

# Auto _INDEX_{Provider}.md under the recall scan root after successful memory_ingest (issue #38)
# CLAWQL_MEMORY_INDEX_PAGE=0
# CLAWQL_MEMORY_INDEX_PROVIDER=ClawQL

# Hybrid memory index (issue #27): SQLite under the vault unless CLAWQL_MEMORY_DB_PATH is absolute.
# CLAWQL_MEMORY_DB=0                    # disable DB sync + recall graph merge
# CLAWQL_MEMORY_DB_PATH=memory.db
# CLAWQL_MEMORY_DB_SYNC_ON_RECALL=1     # optional: rewrite DB from every recall scan (heavier)
# CLAWQL_MEMORY_CHUNK_MAX_CHARS=2000    # paragraph_v1 hard-split threshold

# Optional semantic index + recall (issues #26 / #28) — tradeoffs: docs/hybrid-memory-backends.md
# CLAWQL_VECTOR_BACKEND=sqlite     # vectors in memory.db only (simplest)
# CLAWQL_VECTOR_BACKEND=postgres   # pgvector when CLAWQL_VECTOR_DATABASE_URL is set; else sqlite vectors + warning
# CLAWQL_VECTOR_DATABASE_URL=postgres://user:pass@host:5432/dbname
# CLAWQL_MEMORY_VECTOR_DUAL_WRITE=0   # when using Postgres: vectors in PG only (no BLOBs in memory.db)
# CLAWQL_EMBEDDING_DIMENSION=1536
# CLAWQL_EMBEDDING_BASE_URL=https://api.openai.com/v1
# CLAWQL_EMBEDDING_MODEL=text-embedding-3-small
# CLAWQL_EMBEDDING_API_KEY=…   # or OPENAI_API_KEY
# CLAWQL_MEMORY_VECTOR_MIN_SIM=0.28
# CLAWQL_MEMORY_VECTOR_SCORE_BOOST=50

# Optional: log memory MCP tool invocations as shapes only (no vault text). See docs/memory-db-hybrid-implementation.md §7.
# CLAWQL_MCP_LOG_TOOLS=1

# Cuckoo filter over indexed chunk ids + Merkle root over documents (issues #25 / #37). See docs/memory-db-hybrid-implementation.md §7.
# CLAWQL_CUCKOO_ENABLED=1
# CLAWQL_CUCKOO_FINGERPRINT_BITS=12
# CLAWQL_CUCKOO_METRICS=1
# CLAWQL_MERKLE_ENABLED=1

# ─── Cloudflare Sandbox (`sandbox_exec` MCP tool) ─────────────────────
# The Sandbox SDK runs in a Worker; MCP calls this bridge over HTTPS.
# Deploy: cloudflare/sandbox-bridge/ — set BRIDGE_SECRET to match the token below.
# CLAWQL_SANDBOX_BRIDGE_URL=https://clawql-sandbox-bridge.your-subdomain.workers.dev
# CLAWQL_CLOUDFLARE_SANDBOX_API_TOKEN=
# CLAWQL_CLOUDFLARE_ACCOUNT_ID=
# CLAWQL_SANDBOX_PERSISTENCE_MODE=session
# CLAWQL_SANDBOX_TIMEOUT_MS=120000
# CLAWQL_SANDBOX_TIMEOUT_MS_MAX=300000

# ─── Workflow test toggles ─────────────────────────────────────────────
# Multi-provider workflow: default to dry-run (show request details, do not POST).
WORKFLOW_PREVIEW_JIRA_REQUEST=1
# Set to 1 to actually POST Jira issue.
# WORKFLOW_CREATE_JIRA_ISSUE=1
